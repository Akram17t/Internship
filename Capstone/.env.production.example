# Groq chat and FAQ generation
MODEL=openai/gpt-oss-20b
GROQ_API_KEY=
GROQ_TIMEOUT_SECONDS=240
GROQ_REASONING_EFFORT=low
MODEL_NUM_PREDICT=2000
FAQ_NUM_PREDICT=180

# Nscale hosted embeddings
NSCALE_SERVICE_TOKEN=
NSCALE_BASE_URL=https://inference.api.nscale.com/v1
EMBED_MODEL=Qwen/Qwen3-Embedding-8B
EMBED_BATCH_SIZE=64

# Persistent production storage
APP_STATE_DB=/app/storage/app_state.db
DATA_DIR=/app/storage/data
CHROMA_DIR=/app/storage/chroma_db
SEMANTIC_CACHE_DIR=/app/storage/semantic_chroma

# Retrieval and semantic cache
TOP_K=4
RETRIEVAL_MIN_SCORE=0.3
RERANK_MODEL=cross-encoder/mmarco-mMiniLMv2-L12-H384-v1
SEMANTIC_CACHE_ENABLED=true
SEMANTIC_CACHE_THRESHOLD=0.92
SEMANTIC_CACHE_TOP_K=1

# Frontend
TYPING_ANIMATION_ENABLED=true

# Flowchart extraction via Groq vision
FLOWCHART_EXTRACTION_ENABLED=true
FLOWCHART_DISPLAY_ENABLED=false
FLOWCHART_MODEL=qwen/qwen3.6-27b
FLOWCHART_GROQ_TIMEOUT_SECONDS=240
FLOWCHART_GROQ_REASONING_EFFORT=low
FLOWCHART_MAX_COMPLETION_TOKENS=2048
