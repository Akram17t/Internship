MODEL=ollama/gemma3:12b
OLLAMA_BASE_URL=http://localhost:11434
EMBED_MODEL=aroxima/multilingual-e5-large-instruct
RERANK_MODEL=cross-encoder/mmarco-mMiniLMv2-L12-H384-v1
OLLAMA_NUM_CTX=4096
OLLAMA_NUM_PREDICT=900
FAQ_NUM_PREDICT=220
OLLAMA_TIMEOUT_SECONDS=240
CHROMA_DIR=backend/chroma_db
DATA_DIR=backend/data
TOP_K=4
# Minimum rerank relevance (0-1) for a chunk to count as a real source.
# Off-topic questions fall below this and get an instant "no source" response
# without calling the LLM. Set to 0 to disable the filter.
RETRIEVAL_MIN_SCORE=0.3
