# Chat and FAQ generation via OpenAI-compatible endpoint
MODEL=kr/claude-sonnet-4.5
CHAT_BASE_URL=http://localhost:20128/v1
CHAT_API_KEY=
CHAT_TIMEOUT_SECONDS=240
MODEL_NUM_PREDICT=2000
FAQ_NUM_PREDICT=180

# Nscale hosted embeddings
NSCALE_SERVICE_TOKEN=
NSCALE_BASE_URL=https://inference.api.nscale.com/v1
EMBED_MODEL=Qwen/Qwen3-Embedding-8B
EMBED_BATCH_SIZE=64

# Storage
CHROMA_DIR=backend/chroma_db
DATA_DIR=backend/data
APP_STATE_DB=backend/cache/app_state.db

# Retrieval and semantic cache
TOP_K=4
RETRIEVAL_MIN_SCORE=0.3
RERANK_MODEL=cross-encoder/mmarco-mMiniLMv2-L12-H384-v1
SEMANTIC_CACHE_ENABLED=true
SEMANTIC_CACHE_DIR=backend/cache/semantic_chroma
SEMANTIC_CACHE_THRESHOLD=0.92
SEMANTIC_CACHE_TOP_K=1

# Frontend
TYPING_ANIMATION_ENABLED=true
FAQ_ASSETS_DIR=backend/faq_assets

# Flowchart extraction via OpenAI-compatible vision
FLOWCHART_EXTRACTION_ENABLED=true
FLOWCHART_DISPLAY_ENABLED=false
FLOWCHART_MODEL=kr/claude-sonnet-4.5
FLOWCHART_BASE_URL=http://localhost:20128/v1
FLOWCHART_API_KEY=
FLOWCHART_TIMEOUT_SECONDS=240
FLOWCHART_MAX_COMPLETION_TOKENS=2048
